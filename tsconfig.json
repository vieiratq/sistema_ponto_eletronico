{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "bundler",
    "target" : "esnext",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "outDir" : "./dist",
  },
  "include": ["src"]
}
